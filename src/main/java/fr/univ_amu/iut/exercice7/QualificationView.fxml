<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<!--
  Vue de la pierre angulaire MVC (parcours P3 du brief SAÉ 2.01).

  Le SplitPane à divider 0.62 partage la fenêtre entre :
    - à gauche : un TableView listant les séquences à écouter ;
    - à droite : un panneau de détail avec lecture simulée + verdict global.

  Toutes les colonnes du TableView sont déclarées en FXML (text + fx:id).
  Le contrôleur installera leurs cellValueFactory en Java pour brancher chaque
  colonne sur la propriété correspondante du modèle Sequence.
-->

<SplitPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="fr.univ_amu.iut.exercice7.QualificationController"
           dividerPositions="0.6"
           prefWidth="880.0" prefHeight="520.0">

  <items>

    <!-- Gauche : tableau des séquences à écouter -->
    <TableView fx:id="tableView">
      <columns>
        <TableColumn fx:id="colHorodatage" text="Horodatage" prefWidth="110"/>
        <TableColumn fx:id="colFrequence" text="Fréquence (kHz)" prefWidth="130"/>
        <TableColumn fx:id="colDuree" text="Durée (s)" prefWidth="80"/>
        <TableColumn fx:id="colStatut" text="Statut" prefWidth="100"/>
      </columns>
    </TableView>

    <!-- Droite : panneau de détail -->
    <VBox spacing="12">
      <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
      </padding>

      <Label text="Détail de la séquence"
             style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

      <Label fx:id="labelSelection"
             style="-fx-text-fill: #6a737d;"/>

      <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="boutonEcouter"
                text="▶ Écouter (simulé)"
                onAction="#ecouter"
                style="-fx-base: #4a90d9;"/>
        <Label fx:id="labelLecture"
               style="-fx-text-fill: #27ae60; -fx-font-style: italic;"/>
      </HBox>

      <Separator/>

      <Label text="Verdict global de la nuit :"
             style="-fx-font-weight: bold;"/>

      <ChoiceBox fx:id="choiceBoxVerdict" maxWidth="200"/>

      <Label text="Commentaire libre :"/>

      <TextArea fx:id="zoneCommentaire"
                prefRowCount="3"
                promptText="vent fort vers 02:00, sons à vérifier..."/>

      <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="boutonEnregistrer"
                text="Enregistrer le verdict"
                onAction="#enregistrerVerdict"/>
        <Label fx:id="labelVerdictGlobal"
               style="-fx-text-fill: #2c3e50;"/>
      </HBox>

    </VBox>

  </items>
</SplitPane>
