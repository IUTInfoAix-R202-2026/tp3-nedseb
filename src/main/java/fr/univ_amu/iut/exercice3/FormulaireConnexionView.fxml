<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>

<!--
  Vue du formulaire de connexion.

  Points clefs :
    - fx:controller="..." associe la vue à son controleur Java.
    - fx:id="..." nomme un noeud pour pouvoir l'injecter dans le controleur (@FXML).
    - onAction="#valider" branche un clic sur la méthode `valider()` du controleur.
    - stylesheets="@FormulaireConnexion.css" applique la feuille de style locale.
      (Le @ devant le nom signifie "relatif au FXML".)
-->

<GridPane xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
          fx:controller="fr.univ_amu.iut.exercice3.FormulaireConnexionController"
          stylesheets="@FormulaireConnexion.css"
          styleClass="formulaire"
          hgap="10" vgap="10">

  <padding>
    <Insets top="20" right="20" bottom="20" left="20"/>
  </padding>

  <Label text="Identifiant :"
         GridPane.rowIndex="0" GridPane.columnIndex="0"/>
  <TextField fx:id="champIdentifiant"
             promptText="votre identifiant"
             GridPane.rowIndex="0" GridPane.columnIndex="1"/>

  <Label text="Mot de passe :"
         GridPane.rowIndex="1" GridPane.columnIndex="0"/>
  <PasswordField fx:id="champMotDePasse"
                 promptText="8 car. mini, 1 majuscule, 1 chiffre"
                 GridPane.rowIndex="1" GridPane.columnIndex="1"/>

  <HBox spacing="10" alignment="CENTER_RIGHT"
        GridPane.rowIndex="2" GridPane.columnIndex="0" GridPane.columnSpan="2">
    <Button fx:id="boutonAnnuler"
            text="Annuler"
            onAction="#annuler"/>
    <Button fx:id="boutonOk"
            text="OK"
            styleClass="primary"
            onAction="#valider"/>
  </HBox>

  <Label fx:id="labelMessage"
         styleClass="message"
         GridPane.rowIndex="3" GridPane.columnIndex="0" GridPane.columnSpan="2"/>
</GridPane>
