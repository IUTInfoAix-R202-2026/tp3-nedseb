<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  Vue d'une carte de site (composant réutilisable via fx:root).

  Particularités du pattern fx:root :
    - la racine n'est PAS un type de noeud usuel mais <fx:root type="..."/>.
    - aucun fx:controller n'est déclaré : le contrôleur sera fourni en Java par
      FXMLLoader.setController(this) avant load().
    - le code Java fait aussi setRoot(this) pour que les enfants soient ajoutés
      directement à l'objet courant (ici un HBox).

  Mise en page : à gauche un bloc (carré + nom + badge), au milieu deux blocs de
  stats (points, passages), à droite un chevron visuel pour indiquer la
  cliquabilité (purement esthétique pour cet exercice).
-->

<fx:root type="javafx.scene.layout.HBox"
         xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
         stylesheets="@SiteCarte.css"
         styleClass="carte-site"
         spacing="20">

  <padding>
    <Insets top="14" right="20" bottom="14" left="20"/>
  </padding>

  <!-- Bloc 1 : identité du site + badge de fraîcheur -->
  <VBox spacing="4">
    <Label fx:id="labelCarre" styleClass="carre-no"/>
    <Label fx:id="labelNom" styleClass="carre-nom"/>
    <Label fx:id="labelBadge" styleClass="badge"/>
  </VBox>

  <!-- Espace extensible -->
  <Region HBox.hgrow="ALWAYS"/>

  <!-- Bloc 2 : nombre de points -->
  <VBox spacing="2" styleClass="stat">
    <Label fx:id="labelNbPoints" styleClass="stat-num"/>
  </VBox>

  <!-- Bloc 3 : nombre de passages -->
  <VBox spacing="2" styleClass="stat">
    <Label fx:id="labelNbPassages" styleClass="stat-num"/>
  </VBox>

</fx:root>
